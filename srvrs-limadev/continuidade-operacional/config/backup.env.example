# Global backup configuration for LimaDev
# Copy to /etc/limadev/backup.env and adjust values.

# Restic backend (S3-compatible object storage)
RESTIC_REPOSITORY="s3:s3.us-west-002.backblazeb2.com/limadev-backup"
RESTIC_PASSWORD_FILE="/etc/limadev/restic-password"

# Object storage credentials (least privilege application key/user)
AWS_ACCESS_KEY_ID="CHANGE_ME"
AWS_SECRET_ACCESS_KEY="CHANGE_ME"
AWS_DEFAULT_REGION="us-west-002"

# Retention policy
KEEP_DAILY="7"
KEEP_WEEKLY="4"
KEEP_MONTHLY="6"

# Optional global exclude file
EXCLUDE_FILE="/etc/limadev/excludes/global.txt"

# Telegram alerts (optional but recommended)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Drill behavior
DRILL_CHECK_SUBSET="10%"
DRILL_KEEP_TARGET="0"
