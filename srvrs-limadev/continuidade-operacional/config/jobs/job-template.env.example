# Job template
# Save as /etc/limadev/jobs/<job-name>.env
# Example names: vps-assist-db, vps-prod-db, vps-assist-system

BACKUP_HOST="vps-assist"
BACKUP_CLASS="db"

# Space-separated list of source paths
BACKUP_PATHS="/var/backups/postgres /etc"

# Optional per-job exclude file (overrides global EXCLUDE_FILE)
JOB_EXCLUDE_FILE=""

# Optional shell commands executed before/after backup.
# Example:
# PRE_BACKUP_HOOK="bash /usr/local/bin/limadev-vps-assist-export-postgres.sh"
# POST_BACKUP_HOOK="echo backup-finished"
PRE_BACKUP_HOOK=""
POST_BACKUP_HOOK=""

# Optional custom tags
BACKUP_EXTRA_TAGS="team:infra env:prod"
