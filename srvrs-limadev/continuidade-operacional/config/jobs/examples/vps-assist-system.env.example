# vps-assist system configuration backup job
# Copy to: /etc/limadev/jobs/vps-assist-system.env

BACKUP_HOST="vps-assist"
BACKUP_CLASS="system_config"

BACKUP_PATHS="/etc /root/.hermes /root/.paperclip"

# Recommended: maintain a dedicated exclude file to skip volatile data.
JOB_EXCLUDE_FILE="/etc/limadev/excludes/vps-assist-system.txt"

BACKUP_EXTRA_TAGS="env:prod service:paperclip team:infra"
