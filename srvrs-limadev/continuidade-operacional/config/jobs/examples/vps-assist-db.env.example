# vps-assist critical database backup job
# Copy to: /etc/limadev/jobs/vps-assist-db.env

BACKUP_HOST="vps-assist"
BACKUP_CLASS="db"

# Generated by scripts/vps-assist_export_postgres.sh
BACKUP_PATHS="/var/backups/limadev/postgres"

# Optional per-job excludes
JOB_EXCLUDE_FILE=""

# Export pg_dump before taking snapshot.
PRE_BACKUP_HOOK="bash /usr/local/bin/limadev-vps-assist-export-postgres.sh"
POST_BACKUP_HOOK=""

# Extra tags help filtering snapshots
BACKUP_EXTRA_TAGS="env:prod service:paperclip team:infra"
