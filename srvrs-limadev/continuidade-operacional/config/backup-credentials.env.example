# LimaDev backup credentials vault template
# Copy to a private ignored file before filling secrets:
#   cp srvrs-limadev/continuidade-operacional/config/backup-credentials.env.example \
#      srvrs-limadev/continuidade-operacional/secure/limadev-backup-credentials.env
#
# Do not commit the filled file.

# Metadata
LIMADEV_BACKUP_CREDENTIALS_VERSION="1"
LIMADEV_BACKUP_CREDENTIALS_OWNER="LimaDev"
LIMADEV_BACKUP_CREDENTIALS_UPDATED_AT="YYYY-MM-DD"

# Backblaze B2 / S3-compatible backend
B2_BUCKET_NAME="limadev-backup"
B2_BUCKET_ID="PREENCHER_APOS_CRIAR_BUCKET"
B2_REGION="us-west-002"
B2_S3_ENDPOINT="s3.us-west-002.backblazeb2.com"
B2_APPLICATION_KEY_ID="PREENCHER"
B2_APPLICATION_KEY="PREENCHER"

# Restic repository
RESTIC_REPOSITORY="s3:s3.us-west-002.backblazeb2.com/limadev-backup"
RESTIC_PASSWORD="PREENCHER_SENHA_FORTE_DO_REPOSITORIO_RESTIC"
RESTIC_PASSWORD_SHA256_NOTE="opcional: registrar hash da senha para conferencia sem revelar a senha"

# Host deployment path
HOST_BACKUP_ENV_PATH="/etc/limadev/backup.env"
HOST_RESTIC_PASSWORD_FILE="/etc/limadev/restic-password"
HOST_HEARTBEAT_ENV_PATH="/etc/limadev/heartbeat.env"

# Retention
KEEP_DAILY="7"
KEEP_WEEKLY="4"
KEEP_MONTHLY="6"

# Telegram alerts
TELEGRAM_BOT_TOKEN="PREENCHER"
TELEGRAM_CHAT_ID="PREENCHER"

# Heartbeat / Hermes
HEARTBEAT_EXPECTED_HOSTS="vps-assist vps-prod vps-dev mini-pc note-limdev"
HEARTBEAT_INGEST_SSH_TARGET="limadev-report@vps-assist"
HEARTBEAT_INGEST_COMMAND="limadev-heartbeat-ingest"
HEARTBEAT_USE_HERMES="1"
HEARTBEAT_TELEGRAM_ENABLED="1"

# SSH restricted reporting user
REPORTING_SSH_USER="limadev-report"
REPORTING_SSH_PRIVATE_KEY_LOCATION_NOTE="guardar chave privada fora do repo"
REPORTING_SSH_PUBLIC_KEY="PREENCHER"

# Recovery notes
RECOVERY_PRIORITY_HOSTS="vps-assist vps-prod vps-dev mini-pc note-limdev"
RECOVERY_FIRST_STEPS="Provisionar host limpo, instalar restic, configurar /etc/limadev/backup.env, restaurar system_config, db, app_data."
